PUBLIC_SITE_URL=https://your-domain.example

DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_TEXT_MODEL=deepseek-chat

OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_TEXT_MODEL=openrouter/free

MINIMAX_API_KEY=your_minimax_key
MINIMAX_MUSIC_MODEL=music-2.6

MUREKA_API_KEY=your_mureka_key
MUREKA_MODEL=auto

EMAIL_PROVIDER=aliyun
ALIYUN_MAIL_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_MAIL_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_MAIL_ACCOUNT_NAME=noreply@your-domain.example
ALIYUN_MAIL_FROM_ALIAS=生活集爱音乐
ALIYUN_MAIL_REGION=cn-hangzhou

SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_sms_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_sms_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code
ALIYUN_SMS_REGION=cn-hangzhou

DEV_LOGIN_ENABLED=false
DEV_LOGIN_CODE=change_this_test_code

# Only for local testing. Do not enable this on production unless you understand the risk.
ALLOW_DEV_VERIFY_CODE=false
